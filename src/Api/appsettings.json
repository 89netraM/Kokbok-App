{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Facebook": {
      "CallbackPath": "/auth/facebook/redirect",
      "SignInScheme": "Identity.External"
    },
    "Google": {
      "CallbackPath": "/auth/google/redirect",
      "SignInScheme": "Identity.External"
    },
    "Microsoft": {
      "CallbackPath": "/auth/microsoft/redirect",
      "SignInScheme": "Identity.External"
    }
  }
}
